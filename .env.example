# Set this to a strong secret.
#
# This passphrase is used to AES-GCM encrypt alumni data at build time.
# It becomes the URL fragment required to view the site:
#   https://your-site.com/#your-secret-key
#
# Rules:
#   - Use a long, random string (e.g. from `openssl rand -base64 24`)
#   - Never commit .env to version control
#   - Changing this key requires re-sharing the link
ALUMNI_SECRET_KEY=

# Compact base64-encoded alumni data blob.
# Generated by the /tools/data-import utility page.
ALUMNI_DATA=

---
import { Image } from "astro:assets";
import { badgeVariants } from "@/components/ui/badge";
import { buttonVariants } from "@/components/ui/button";
import overview from "../assets/overview.png";
import AlumniApp from "../components/AlumniApp";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<!-- Header -->
	<header class="sticky top-0 z-40 border-b bg-background/80 backdrop-blur">
		<div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
			<a href="/" aria-label="The Hive home">
				<img src="/logo-light.svg" alt="The Hive Alumni" class="h-8 w-auto dark:hidden" />
				<img src="/logo-dark.svg" alt="The Hive Alumni" class="hidden h-8 w-auto dark:block" />
			</a>
			<nav aria-label="External links">
				<a
					href="https://hive.ece.gatech.edu/"
					target="_blank"
					rel="noopener noreferrer"
					class={buttonVariants({ variant: "ghost", size: "sm" })}
				>
					Visit The Hive →
				</a>
			</nav>
		</div>
	</header>

	<!-- Hero -->
	<section class="relative overflow-hidden border-b bg-card">
		<Image
			src={overview}
			alt=""
			aria-hidden="true"
			class="absolute inset-0 h-full w-full scale-105 object-cover blur-[2px]"
			loading="eager"
		/>
		<div class="absolute inset-0 bg-background/75"></div>
		<div class="relative mx-auto max-w-7xl px-6 py-14 text-center md:py-20">
			<h1 class="font-heading mt-4 text-3xl font-semibold tracking-tight md:text-5xl">
				Hive Alumni Directory
			</h1>
			<p class="mx-auto mt-4 max-w-2xl text-base text-muted-foreground md:text-lg">
				See where graduates of The Hive Makerspace at Georgia Tech have landed
				around the world.
			</p>
		</div>
	</section>

	<!-- Main Content -->
	<main id="main" class="mx-auto w-full max-w-7xl px-6 py-8 md:py-10">
		<AlumniApp client:only="react" />
	</main>

	<!-- Footer -->
	<footer class="mt-12 border-t">
		<div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-8 sm:flex-row">
			<img src="/logo-light.svg" alt="" class="h-6 w-auto opacity-40 dark:hidden" />
			<img src="/logo-dark.svg" alt="" class="hidden h-6 w-auto opacity-40 dark:block" />
			<p class="text-xs text-muted-foreground">
				Georgia Institute of Technology &bull; Atlanta, GA
			</p>
		</div>
	</footer>
</Layout>

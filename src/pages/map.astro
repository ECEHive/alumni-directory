---
import "../styles/global.css";
import MapApp from "../components/MapApp";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/favicon.ico" />
		<title>Alumni Map | The Hive</title>
		<meta
			name="description"
			content="Interactive map of Hive Makerspace alumni across the United States."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
		/>
		<style>
			html,
			body {
				height: 100%;
				margin: 0;
				overflow: hidden;
			}
		</style>
	</head>
	<body
		class="h-screen overflow-hidden bg-white text-gray-900 dark:bg-hive-darker dark:text-white"
	>
		<MapApp client:only="react" />
	</body>
</html>

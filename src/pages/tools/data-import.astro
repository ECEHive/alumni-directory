---
import DataImportApp from "../../components/tools/DataImportApp";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Data Import Tool | Hive Alumni">
	<header
		class="border-b border-gray-200 dark:border-white/10 bg-white/80 dark:bg-hive-dark/80 backdrop-blur-md sticky top-0 z-50"
	>
		<div class="max-w-5xl mx-auto px-6 py-4 flex items-center gap-4">
			<a
				id="back-link"
				href="/"
				class="text-sm text-gray-500 dark:text-white/50 hover:text-gt-gold transition-colors"
			>
				← Back
			</a>
			<span class="text-gray-300 dark:text-white/20 select-none">|</span>
			<span class="text-sm font-semibold text-gray-900 dark:text-white"
				>Data Import Tool</span
			>
			<span
				class="ml-auto text-xs bg-gt-gold/15 text-gt-gold px-2.5 py-1 rounded-full font-medium"
			>
				Dev Utility
			</span>
		</div>
	</header>

	<main class="max-w-5xl mx-auto px-6 py-10">
		<DataImportApp client:only="react" />
	</main>
</Layout>

<script>
	const link = document.getElementById("back-link") as HTMLAnchorElement;
	if (link && window.location.hash) {
		link.href = `/${window.location.hash}`;
	}
</script>
